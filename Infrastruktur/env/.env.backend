# Database
DATABASE_URL=mysql://root:${DB_ROOT_PASSWORD}@db:3306/whatsapp_gateway

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# JWT
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRES_IN=7d

# Sessions
SESSION_DIR=./sessions

# Worker
WORKER_INTERVAL_MS=5000
MESSAGE_DELAY_MS=6000

# CORS (proxy handles this, but backend still needs it)
FRONTEND_URL=${FRONTEND_URL}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}

# Optional: AWS S3 session storage
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Optional: Payment Gateway (Midtrans)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=true

# Optional: AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
